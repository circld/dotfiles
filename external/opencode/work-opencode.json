{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "octane_llm_proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Octane LLM Proxy",
      "options": {
        "baseURL": "{env:OCTANE_LLM_PROXY_URL}",
        "apiKey": "{env:OCTANE_API_KEY}",
        "litellmProxy": true,
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "minimax-m3": {
          "name": "Minimax M3",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 0.3,
            "output": 1.2
          }
        },
        "claude-opus-4-8": {
          "name": "Claude Opus 4.8",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking": {
              "type": "adaptive"
            }
          },
          "cost": {
            "input": 5.0,
            "output": 25.0
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 3.0,
            "output": 15.0
          }
        },
        "glm-5.2": {
          "name": "GLM 5.2",
          "attachment": false,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 1.4,
            "output": 4.4
          }
        }
      }
    },
    "octane_llm_proxy_openai": {
      "npm": "@ai-sdk/openai",
      "name": "Octane LLM Proxy",
      "options": {
        "baseURL": "{env:OCTANE_LLM_PROXY_URL}",
        "apiKey": "{env:OCTANE_API_KEY}",
        "litellmProxy": true,
        "timeout": 600000,
        "chunkTimeout": 180000
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 1.25,
            "output": 10.0,
            "cache_read": 0.125,
            "cache_write": 0.0
          }
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 5.0,
            "output": 30.0
          }
        }
      }
    }
  },
  "tools": {
    "websearch_*": false
  },
  "agent": {
    "researcher": {
      "tools": {
        "websearch_*": true
      }
    },
    "goldfish-reviewer": {
      "model": "octane_llm_proxy/minimax-m3"
    },
    "code-reviewer": {
      "model": "octane_llm_proxy/minimax-m3"
    }
  },
  "mcp": {
    "confluence": {
      "type": "remote",
      "url": "{env:OCTANE_MCP_BASE_URL}/mcp/confluence",
      "enabled": true,
      "headers": {
        "OCTANE_API_KEY": "{env:OCTANE_API_KEY}"
      }
    },
    "jira": {
      "type": "remote",
      "url": "{env:OCTANE_MCP_BASE_URL}/mcp/jira",
      "enabled": true,
      "headers": {
        "OCTANE_API_KEY": "{env:OCTANE_API_KEY}"
      }
    }
  }
}
