{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "octane_llm_proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Octane LLM Proxy",
      "options": {
        "baseURL": "{env:OCTANE_LLM_PROXY_URL}",
        "apiKey": "{env:OCTANE_API_KEY}",
        "litellmProxy": true,
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "bedrock-minimax-m2.1": {
          "name": "MiniMax M2.1",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 0.3,
            "output": 1.2,
            "cache_read": 0.125,
            "cache_write": 0.0
          }
        },
        "claude-opus-4.6": {
          "name": "Claude Opus 4.6",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budget_tokens": 16000
            }
          },
          "cost": {
            "input": 5.0,
            "output": 25.0
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 3.0,
            "output": 15.0
          }
        }
      }
    },
    "octane_llm_proxy_openai": {
      "npm": "@ai-sdk/openai",
      "name": "Octane LLM Proxy",
      "options": {
        "baseURL": "{env:OCTANE_LLM_PROXY_URL}",
        "apiKey": "{env:OCTANE_API_KEY}",
        "litellmProxy": true,
        "timeout": 600000,
        "chunkTimeout": 180000
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 1.25,
            "output": 10.0,
            "cache_read": 0.125,
            "cache_write": 0.0
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          },
          "cost": {
            "input": 1.25,
            "output": 10.0,
            "cache_read": 0.125,
            "cache_write": 0.0
          }
        }
      }
    }
  },
  "agent": {
    "goldfish": {
      "model": "octane_llm_proxy_openai/gpt-5.4"
    },
    "code-reviewer": {
      "model": "octane_llm_proxy_openai/gpt-5.3-codex"
    }
  },
  "mcp": {
    "confluence": {
      "type": "remote",
      "url": "{env:OCTANE_MCP_BASE_URL}/mcp/confluence",
      "enabled": true,
      "headers": {
        "OCTANE_API_KEY": "{env:OCTANE_API_KEY}"
      }
    },
    "jira": {
      "type": "remote",
      "url": "{env:OCTANE_MCP_BASE_URL}/mcp/jira",
      "enabled": true,
      "headers": {
        "OCTANE_API_KEY": "{env:OCTANE_API_KEY}"
      }
    }
  }
}
